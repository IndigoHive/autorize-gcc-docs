{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Autorize Docs",
  "colors": {
    "primary": "#78C2EA",
    "light": "#0056DB",
    "dark": "#17438F"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Inicio",
        "icon": "home",
        "groups": [
          {
            "group": "Comece aqui",
            "pages": [
              "index"
            ]
          }
        ]
      },
      {
        "tab": "Guias",
        "icon": "book",
        "groups": [
          {
            "group": "Visão geral",
            "pages": [
              "guias/fluxo-da-informacao",
              "guias/vincular-gcc"
            ]
          },
          {
            "group": "Integração",
            "pages": [
              "guias/chaves-de-api"
            ]
          },
          {
            "group": "Ajuda",
            "pages": [
              "guias/glossário"
            ]
          }
        ]
      },
      {
        "tab": "Referência",
        "icon": "code",
        "groups": [
          {
            "group": "Informações",
            "pages": [
              "api-reference/index",
              "api-reference/swagger"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "https://usuario-api.autorize.com.br/swagger/v1/swagger.json"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "autorize.com.br",
          "href": "https://autorize.com.br/",
          "icon": "globe"
        },
        {
          "anchor": "Plataforma Titular",
          "href": "https://titular.autorize.com.br/",
          "icon": "user"
        },
        {
          "anchor": "Plataforma Usuário",
          "href": "https://usuario.autorize.com.br/",
          "icon": "building"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Entre em contato",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://usuario.autorize.com.br/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/autorizegcc/"
    }
  }
}
